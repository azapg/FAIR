{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "The Fair Docs",
  "description": "FAIR is an open-source LMS for assignments, AI agents, chat, grading, and reproducible research.",
  "colors": {
    "primary": "#ff0000"
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "family": "Host Grotesk"
  },
  "logo": {
    "dark": "/assets/fair-docs-dark.svg",
    "light": "/assets/fair-docs.svg"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/azapg/fair",
          "icon": "github"
        },
        {
          "anchor": "PyPI",
          "href": "https://pypi.org/project/fair-platform/",
          "icon": "box"
        }
      ]
    },
    "languages": [
      {
        "language": "en",
        "default": true,
        "banner": {
          "content": "The Fair Platform v0.8 is now live! See our [changelog](/en/changelog) for details.",
          "dismissible": true
        },
        "tabs": [
          {
            "tab": "Docs",
            "icon": "book",
            "groups": [
              {
                "group": "Introduction",
                "pages": [
                  "en/introduction",
                  "en/quickstart",
                  "en/cli",
                  "en/troubleshooting",
                  "en/roadmap"
                ]
              },
              {
                "group": "Platform",
                "pages": [
                  "en/platform/courses",
                  "en/platform/assignments",
                  "en/platform/flows",
                  "en/platform/integrations",
                  "en/platform/settings"
                ]
              },
              {
                "group": "Development",
                "pages": [
                  "en/api-reference/releases",
                  "en/api-reference/migrations",
                  "en/api-reference/dev-env",
                  "en/api-reference/settings-system"
                ]
              }
            ]
          },
          {
            "tab": "Extensions Reference",
            "openapi": "assets/openapi.json",
            "icon": "code",
            "groups": [
              {
                "group": "Start here",
                "pages": [
                  "en/extensions/overview",
                  "en/extensions/manifests",
                  "en/extensions/capabilities"
                ]
              },
              {
                "group": "Run Capabilities",
                "pages": [
                  "en/extensions/installations",
                  "en/extensions/executions",
                  "en/extensions/delivery",
                  "en/extensions/events",
                  "en/extensions/artifacts",
                  "en/extensions/tools",
                  "en/extensions/security"
                ]
              },
              {
                "group": "Product integration",
                "pages": [
                  "en/extensions/agents-and-chat",
                  "en/extensions/assignments-and-grading"
                ]
              },
              {
                "group": "SDK",
                "pages": [
                  "en/extensions/sdk-status"
                ]
              }
            ]
          },
          {
            "tab": "Changelog",
            "icon": "archive",
            "groups": [
              {
                "group": "Platform",
                "pages": ["en/changelog"]
              }
            ]
          }
        ]
      },
      {
        "language": "es",
        "banner": {
          "content": "¡The Fair Platform v0.8 ya está disponible! Consulta nuestro [changelog](/es/changelog) para más detalles.",
          "dismissible": true
        },
        "tabs": [
          {
            "tab": "Docs",
            "icon": "book",
            "groups": [
              {
                "group": "Introducción",
                "pages": [
                  "es/introduction",
                  "es/quickstart",
                  "es/cli",
                  "es/troubleshooting",
                  "es/roadmap"
                ]
              },
              {
                "group": "Plataforma",
                "pages": [
                  "es/platform/extension-architecture",
                  "es/platform/foundational-api",
                  "es/platform/flows",
                  "es/platform/integrations",
                  "es/platform/settings"
                ]
              }
            ]
          },
          {
            "tab": "Changelog",
            "icon": "archive",
            "groups": [
              {
                "group": "Plataforma",
                "pages": ["es/changelog"]
              }
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/azapg/fair"
    },
    "links": [
      {
        "header": "Project",
        "items": [
          {
            "label": "Repository",
            "href": "https://github.com/azapg/fair"
          },
          {
            "label": "License (GPL-3.0)",
            "href": "https://github.com/azapg/fair/blob/main/LICENSE"
          }
        ]
      },
      {
        "header": "Docs",
        "items": [
          {
            "label": "English",
            "href": "/en/introduction"
          },
          {
            "label": "Español",
            "href": "/es/introduction"
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "grok"]
  }
}
